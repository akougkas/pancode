{
  "name": "pancode",
  "version": "0.3.0",
  "description": "Composable multi-agent runtime for software engineering",
  "type": "module",
  "author": "Anthony Kougkas <akougkas@gmail.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/akougkas/pancode.git"
  },
  "homepage": "https://pancode.dev",
  "bugs": {
    "url": "https://github.com/akougkas/pancode/issues"
  },
  "keywords": [
    "multi-agent",
    "coding-agent",
    "orchestrator",
    "ai",
    "runtime",
    "dispatch",
    "local-llm"
  ],
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "pancode": "dist/loader.js"
  },
  "scripts": {
    "build:pi-tui": "npm run build -w @pancode/pi-tui",
    "build:pi-ai": "npm run build -w @pancode/pi-ai",
    "build:pi-agent-core": "npm run build -w @pancode/pi-agent-core",
    "build:pi-coding-agent": "npm run build -w @pancode/pi-coding-agent",
    "build:pi": "npm run build:pi-tui && npm run build:pi-ai && npm run build:pi-agent-core && npm run build:pi-coding-agent",
    "build": "npm run build:pi && tsup",
    "dev": "npm run build:pi && PANCODE_INSIDE_TMUX=1 node --import tsx src/loader.ts",
    "check-boundaries": "node scripts/check-boundaries.mjs",
    "check-constitution": "tsx scripts/constitution-audit.ts",
    "check-prompts": "node scripts/check-prompts.mjs",
    "lint": "biome check src/",
    "typecheck": "npm run build:pi && node scripts/check-boundaries.mjs && node scripts/check-prompts.mjs && tsc --noEmit",
    "postinstall": "node scripts/link-workspace-packages.cjs",
    "smoke-test": "tsx scripts/smoke-test-baseline.ts",
    "verify-tui": "tsx src/domains/ui/tui-verify.ts",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/**/*.js",
    "packages/*/dist/**/*.js",
    "packages/*/package.json",
    "packages/pi-ai/bedrock-provider.js",
    "packages/pi-coding-agent/dist/modes/interactive/theme/*.json",
    "packages/pi-coding-agent/dist/core/export-html/template.html",
    "packages/pi-coding-agent/dist/core/export-html/template.css",
    "models/",
    "scripts/link-workspace-packages.cjs"
  ],
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.81",
    "@anthropic-ai/sdk": "^0.73.0",
    "@aws-sdk/client-bedrock-runtime": "^3.983.0",
    "@google/genai": "^1.40.0",
    "@lmstudio/sdk": "^1.5.0",
    "@mariozechner/jiti": "^2.6.2",
    "@mistralai/mistralai": "1.14.1",
    "@pancode/pi-agent-core": "file:packages/pi-agent-core",
    "@pancode/pi-ai": "file:packages/pi-ai",
    "@pancode/pi-coding-agent": "file:packages/pi-coding-agent",
    "@pancode/pi-tui": "file:packages/pi-tui",
    "@silvia-odwyer/photon-node": "^0.3.4",
    "@sinclair/typebox": "^0.34.48",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "chalk": "^5.6.2",
    "cli-highlight": "^2.1.11",
    "diff": "^8.0.2",
    "extract-zip": "^2.0.1",
    "file-type": "^21.1.1",
    "get-east-asian-width": "^1.3.0",
    "glob": "^13.0.1",
    "hosted-git-info": "^9.0.2",
    "ignore": "^7.0.5",
    "marked": "^15.0.12",
    "minimatch": "^10.2.3",
    "ollama": "^0.6.3",
    "openai": "6.26.0",
    "partial-json": "^0.1.7",
    "proper-lockfile": "^4.1.2",
    "proxy-agent": "^6.5.0",
    "strip-ansi": "^7.1.0",
    "undici": "^7.19.1",
    "yaml": "^2.8.2"
  },
  "optionalDependencies": {
    "@mariozechner/clipboard": "^0.3.2",
    "koffi": "^2.9.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/diff": "^7.0.2",
    "@types/hosted-git-info": "^3.0.5",
    "@types/node": "^22.0.0",
    "@types/proper-lockfile": "^4.1.4",
    "tsup": "^8.5.1",
    "tsx": "^4.0.0",
    "typescript": "~5.7.0"
  }
}
