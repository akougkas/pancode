---
const stats = [
  { value: "7", label: "Runtime Adapters" },
  { value: "10", label: "Composable Domains" },
  { value: "4", label: "Safety Modes" },
  { value: "35+", label: "Commands" },
];

const taxonomy = [
  {
    id: "01",
    title: "Pan-provider",
    description:
      "Route local engines, frontier APIs, or hybrid fleets without standardizing on a single vendor.",
  },
  {
    id: "02",
    title: "Pan-model",
    description:
      "Match model capability, latency, and cost to the task instead of hard-wiring one model into the workflow.",
  },
  {
    id: "03",
    title: "Pan-runtime",
    description:
      "Run native workers, SDK-backed agents, or headless CLIs under one worker contract and one control plane.",
  },
  {
    id: "04",
    title: "Pan-agent",
    description:
      "Discover installed coding agents automatically and operate them as a coordinated fleet instead of isolated tools.",
  },
  {
    id: "05",
    title: "Pan-safety",
    description:
      "Apply a shared safety model across runtimes so scope, privileges, and escalation rules stay coherent.",
  },
  {
    id: "06",
    title: "Pan-observe",
    description:
      "Track cost, tokens, turns, receipts, and runtime status from the same terminal session that launches the work.",
  },
];

const workflow = [
  {
    step: "01",
    title: "Discover agents",
    description:
      "Scan the machine for installed runtimes and register each worker with one consistent capability model.",
  },
  {
    step: "02",
    title: "Configure the fleet",
    description:
      "Adjust presets, safety, models, and budgets through conversation instead of bouncing across config files.",
  },
  {
    step: "03",
    title: "Dispatch with control",
    description:
      "Route work by capability, cost, and privilege scope while keeping worker execution isolated and reproducible.",
  },
  {
    step: "04",
    title: "Observe everything",
    description:
      "Read receipts, cost, runtime health, and status updates from one terminal-native control surface.",
  },
];

const highlights = [
  {
    eyebrow: "Constitutional Prompt System",
    title: "Prompt policy is compiled before any worker sees the task.",
    body:
      "PanCode assembles prompts from audited fragments, then runs boundary and constitutional checks before execution. Modes, safety scopes, and runtime adapters inherit the same behavioral contract instead of drifting apart over time.",
    snippetLabel: "prompt.audit",
    snippet: [
      "$ npm run check-prompts",
      "[pass] fragments resolved: mode/build + safety/auto-edit",
      "[pass] constitutional references intact",
      "[pass] worker prompt compiled",
    ],
  },
  {
    eyebrow: "Dispatch Pipeline",
    title: "Every run leaves behind a receipt you can reason about.",
    body:
      "Dispatch is not a black box. PanCode records worker identity, scope, tokens, cost, and outcomes so operators can understand what happened, replay decisions, and tune the fleet with evidence instead of guesswork.",
    snippetLabel: "dispatch.receipt",
    snippet: [
      "/dispatch reviewer src/core/config.ts",
      "run      rec_20260323_1841",
      "worker   reviewer.codex readonly",
      "cost     $0.14   28944 tokens",
      "result   receipt stored in .pancode/runtime/results/",
    ],
  },
  {
    eyebrow: "Conversational Configuration",
    title: "Change the runtime in plain English and keep the state on disk.",
    body:
      "Presets, worker models, budgets, and orchestration behavior can be adjusted through conversation, then persisted to the same project and user configuration files PanCode already owns. The interface feels immediate because it is grounded in real runtime state.",
    snippetLabel: "configure.session",
    snippet: [
      'You: "Switch the worker pool to local codellama"',
      "PanCode: updated preset.hybrid.workerModel",
      "PanCode: wrote ~/.pancode/panpresets.yaml",
      "PanCode: reloading worker pool",
    ],
  },
];

const layers = [
  {
    name: "CLI",
    detail: "Commands, session control, and the terminal entry surface for operators.",
  },
  {
    name: "Entry",
    detail: "Boot orchestration, environment setup, and runtime startup sequencing.",
  },
  {
    name: "Core",
    detail: "Config, presets, event bus, agent profiles, and domain loading.",
  },
  {
    name: "Domains",
    detail: "Safety, prompts, dispatch, observability, scheduling, session, and UI capabilities.",
  },
  {
    name: "Engine",
    detail: "Runtime adapters and the sole boundary for SDK-facing integration.",
  },
];
---

<div class="landing-page not-content">
  <div class="preview-bar">
    <div class="landing-boundary preview-bar__inner">
      <div class="preview-bar__copy">
        <span class="preview-pill">Experimental Preview</span>
        <p>
          <strong>v0.3.0-exp</strong> ships the runtime early and on purpose. The APIs may shift. The
          control-plane thesis will not.
        </p>
      </div>
      <a href="https://github.com/akougkas/pancode/releases" target="_blank" rel="noopener noreferrer">
        Release Notes
      </a>
    </div>
  </div>

  <section class="landing-boundary hero-section">
    <div class="hero-copy">
      <div class="hero-meta">
        <span>Terminal-native</span>
        <span>Local-first</span>
        <span>Apache 2.0</span>
      </div>
      <p class="hero-kicker">Composable multi-agent runtime for software engineering</p>
      <h1>One Runtime.<br />Every Agent.</h1>
      <p class="hero-summary">
        PanCode orchestrates coding agents across local models, cloud APIs, and mixed fleets from one
        serious terminal control plane.
      </p>
      <p class="hero-assertion">Not a chatbot. Not a plugin. The runtime.</p>
      <div class="hero-actions">
        <a class="button button--primary" href="/getting-started/installation/">Get Started</a>
        <a
          class="button button--secondary"
          href="https://github.com/akougkas/pancode"
          target="_blank"
          rel="noopener noreferrer"
        >
          GitHub
        </a>
      </div>
    </div>

    <div class="hero-console">
      <div class="terminal-window terminal-window--hero">
        <div class="terminal-window__chrome">
          <div class="terminal-window__controls" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </div>
          <div class="terminal-window__title">~/research/pancode</div>
          <div class="terminal-window__status">secure local session</div>
        </div>
        <div class="terminal-window__ribbon">
          <span class="is-active">boot</span>
          <span>fleet</span>
          <span>receipts</span>
        </div>
        <div class="terminal-window__body">
          <pre><code><span class="terminal-prompt">$</span> pancode --preset hybrid
<span class="terminal-muted">booting control plane...</span>

<span class="terminal-label">discover</span> scanning PATH for runtimes
<span class="terminal-ok">ok</span> claude-code        CLI        anthropic/claude-sonnet-4
<span class="terminal-ok">ok</span> codex              CLI        openai/codex-mini
<span class="terminal-ok">ok</span> gemini-cli         CLI        google/gemini-2.5-pro
<span class="terminal-ok">ok</span> opencode           CLI        anthropic/claude-sonnet-4
<span class="terminal-ok">ok</span> native-worker      NATIVE     local/llama3.3-70b

<span class="terminal-label">load</span> domains
agents dispatch safety prompts session observability scheduling configure ui

<span class="terminal-label">summary</span> 7 adapters   10 domains   receipts on   budget live
<span class="terminal-ok">ready</span> pancode v0.3.0-exp
<span class="terminal-mode">[build]</span> dispatch ready <span class="terminal-cursor"></span></code></pre>
        </div>
      </div>
      <p class="hero-console__caption">
        Discovered on boot: Claude Code, Codex, Gemini CLI, OpenCode, Cline, Copilot CLI, and native
        workers.
      </p>
    </div>
  </section>

  <section class="stats-ribbon">
    <div class="landing-boundary stats-ribbon__inner">
      {
        stats.map((stat) => (
          <div class="stats-ribbon__item">
            <strong>{stat.value}</strong>
            <span>{stat.label}</span>
          </div>
        ))
      }
    </div>
  </section>

  <section class="landing-boundary landing-section" id="taxonomy">
    <div class="section-intro">
      <p class="section-kicker">The Pan Taxonomy</p>
      <h2>Six dimensions of universality.</h2>
      <p>
        PanCode does not win by being one more agent. It wins by giving heterogeneous agent fleets one
        runtime, one policy model, and one operational surface.
      </p>
    </div>
    <div class="taxonomy-grid">
      {
        taxonomy.map((item) => (
          <article class="taxonomy-card">
            <span class="taxonomy-card__index">{item.id}</span>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="landing-boundary landing-section" id="workflow">
    <div class="section-intro">
      <p class="section-kicker">How PanCode Works</p>
      <h2>One pipeline from discovery to observability.</h2>
      <p>
        The system is designed like infrastructure, not like a chat window. Each step narrows ambiguity
        and increases operator control.
      </p>
    </div>
    <div class="workflow-grid">
      {
        workflow.map((item) => (
          <article class="workflow-step">
            <span class="workflow-step__index">{item.step}</span>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="landing-boundary landing-section" id="highlights">
    <div class="section-intro">
      <p class="section-kicker">Feature Highlights</p>
      <h2>The capabilities that make the runtime defensible.</h2>
      <p>
        PanCode is opinionated where the orchestration layer has to be opinionated: policy, dispatch, and
        stateful control over the fleet.
      </p>
    </div>
    <div class="feature-stack">
      {
        highlights.map((feature, index) => (
          <article class:list={["feature-band", { "feature-band--reverse": index % 2 === 1 }]}>
            <div class="feature-band__copy">
              <p class="feature-band__eyebrow">{feature.eyebrow}</p>
              <h3>{feature.title}</h3>
              <p>{feature.body}</p>
            </div>
            <div class="feature-band__preview">
              <div class="signal-panel">
                <div class="signal-panel__label">{feature.snippetLabel}</div>
                <pre><code>{feature.snippet.join("\n")}</code></pre>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="landing-boundary landing-section" id="architecture">
    <div class="section-intro">
      <p class="section-kicker">Architecture</p>
      <h2>Five layers. Clear boundaries.</h2>
      <p>
        The stack is composable by design. CLI entry, core orchestration, and runtime integration stay
        separate so the system scales without becoming opaque.
      </p>
    </div>
    <div class="architecture-layout">
      <div class="architecture-stack">
        {
          layers.map((layer, index) => (
            <div class="architecture-layer" style={`--layer-offset: ${index * 1.15}rem;`}>
              <span class="architecture-layer__index">{String(index + 1).padStart(2, "0")}</span>
              <div>
                <h3>{layer.name}</h3>
                <p>{layer.detail}</p>
              </div>
            </div>
          ))
        }
      </div>
      <div class="architecture-notes">
        <p>
          Engine imports stay behind a single boundary. Worker processes stay isolated. Domains load in
          dependency order and communicate through an event bus instead of mutating each other directly.
        </p>
      </div>
    </div>
  </section>

  <section class="landing-boundary landing-section" id="quickstart">
    <div class="quickstart-panel">
      <div class="quickstart-copy">
        <p class="section-kicker">Quick Start</p>
        <h2>Running in 60 seconds.</h2>
        <p>
          Install the runtime, boot a local preset, and reattach whenever you want. Node.js 20+ and tmux
          are the only prerequisites.
        </p>
      </div>
      <div class="terminal-window terminal-window--compact">
        <div class="terminal-window__chrome">
          <div class="terminal-window__controls" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </div>
          <div class="terminal-window__title">quickstart</div>
          <div class="terminal-window__status">operator path</div>
        </div>
        <div class="terminal-window__body">
          <pre><code><span class="terminal-prompt">$</span> npm install -g pancode
<span class="terminal-prompt">$</span> pancode --preset local
<span class="terminal-prompt">$</span> pancode up</code></pre>
        </div>
      </div>
    </div>
  </section>

  <footer class="landing-boundary landing-footer">
    <p>pancode-exp / Experimental Preview / Apache 2.0 / Built by Anthony Kougkas</p>
    <div class="landing-footer__links">
      <a href="https://github.com/akougkas/pancode" target="_blank" rel="noopener noreferrer">GitHub</a>
      <a href="/getting-started/installation/">Docs</a>
      <a href="https://github.com/akougkas/pancode/releases" target="_blank" rel="noopener noreferrer">
        Release Notes
      </a>
    </div>
  </footer>
</div>
